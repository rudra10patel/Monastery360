# Environment variables for Monastery360
# Copy this file to .env.local and update the values

# App Configuration
VITE_APP_TITLE=Monastery360
VITE_APP_DESCRIPTION=Digital Heritage Platform for Sikkim's Sacred Monasteries
VITE_APP_URL=https://monastery360.netlify.app

# API Configuration (if needed)
# VITE_API_BASE_URL=https://api.monastery360.com
# VITE_API_KEY=your_api_key_here

# Map Configuration
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=© OpenStreetMap contributors

# Analytics (optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_GTM_ID=GTM-XXXXXXX
